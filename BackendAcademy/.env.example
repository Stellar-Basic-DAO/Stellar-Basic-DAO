# =============================================================================
#  Stellar Basic DAO -- BackendAcademy Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# All variables marked as REQUIRED must be set for the application to start.
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Port number for the HTTP server (default: 3000)
PORT=3000

# Node environment: development | production | test (default: development)
NODE_ENV=development

# CORS allowed origin (default: http://localhost:3000)
CORS_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Database Configuration (Required for most features)
# -----------------------------------------------------------------------------

# Database connection URL (PostgreSQL via TypeORM)
DATABASE_URL=postgresql://postgres:password@localhost:5432/stellar-basic-dao-academy

# -----------------------------------------------------------------------------
# Redis Configuration (Optional -- for caching and rate limiting)
# -----------------------------------------------------------------------------

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Authentication (Required for auth features)
# -----------------------------------------------------------------------------

# Secret key for signing JWT tokens
JWT_SECRET=change_me_in_production

# API key secret for API key validation
API_KEY_SECRET=change_me_in_production

# -----------------------------------------------------------------------------
# AI Provider Configuration (Optional)
# -----------------------------------------------------------------------------

# AI provider to use: claude | openai | mock
AI_PROVIDER=mock

# Claude API configuration (required when AI_PROVIDER=claude)
ANTHROPIC_API_KEY=

# OpenAI API configuration (required when AI_PROVIDER=openai)
OPENAI_API_KEY=

# AI model name override (optional)
AI_MODEL=

# Maximum tokens per AI response (default: 4096)
AI_MAX_TOKENS=4096

# Sampling temperature (default: 0.7)
AI_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# Static & Uploaded Assets (Optional)
# -----------------------------------------------------------------------------

# Where uploaded assets are persisted on disk
ASSETS_UPLOAD_DIR=./data/uploads

# Max upload size in megabytes (default: 10)
ASSETS_MAX_SIZE_MB=10

# Base URL advertised inside asset metadata
ASSETS_BASE_URL=/api/v1/assets

# Read-only static asset directory served at /static/
ASSETS_STATIC_DIR=./public
