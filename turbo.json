{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "type-check": {
      "dependsOn": [
        "^type-check"
      ]
    },
    "test": {
      "dependsOn": [
        "^build"
      ]
    },
    "test:root": {
      "cache": false,
      "dependsOn": []
    },
    "test:e2e": {
      "dependsOn": [
        "build"
      ]
    },
    "db:migrate": {
      "cache": false,
      "persistent": false
    }
  }
}